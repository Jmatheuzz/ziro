<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-refresh-token" author="joao">
        <createTable tableName="refresh_token">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="varchar(500)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="usuario_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="expira_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="revogado" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="refresh_token" baseColumnNames="usuario_id"
                                  constraintName="fk_refresh_token_usuario"
                                  referencedTableName="usuario" referencedColumnNames="id"
                                  onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003-create-token-verificacao-email" author="joao">
        <createTable tableName="token_verificacao_email">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codigo" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="usuario_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="expira_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="usado" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="token_verificacao_email" baseColumnNames="usuario_id"
                                  constraintName="fk_token_verificacao_usuario"
                                  referencedTableName="usuario" referencedColumnNames="id"
                                  onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003-create-token-recuperacao-senha" author="joao">
        <createTable tableName="token_recuperacao_senha">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codigo" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="usuario_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="expira_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="usado" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="token_recuperacao_senha" baseColumnNames="usuario_id"
                                  constraintName="fk_token_recuperacao_usuario"
                                  referencedTableName="usuario" referencedColumnNames="id"
                                  onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
