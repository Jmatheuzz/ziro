<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-empresa" author="joao">
        <createTable tableName="empresa">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome_fantasia" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="razao_social" type="varchar(150)"/>
            <column name="cnpj_cpf" type="varchar(20)"/>
            <column name="segmento" type="varchar(50)"/>
            <column name="ativa" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="criado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
