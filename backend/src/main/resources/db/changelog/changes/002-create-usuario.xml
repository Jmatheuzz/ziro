<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-usuario" author="joao">
        <createTable tableName="usuario">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(150)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="senha_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="empresa_id" type="uuid"/>
            <column name="criado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="usuario" baseColumnNames="empresa_id"
                                  constraintName="fk_usuario_empresa"
                                  referencedTableName="empresa" referencedColumnNames="id"
                                  onDelete="SET NULL"/>

        <createIndex tableName="usuario" indexName="idx_usuario_empresa">
            <column name="empresa_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
