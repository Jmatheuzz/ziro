# Copie esse arquivo pra .env e ajuste os valores antes de subir o docker-compose

# Banco de dados
DB_NAME=ziro
DB_USER=ziro
DB_PASSWORD=troque-essa-senha
DB_PORT_EXPOSED=5432

# Backend
BACKEND_PORT_EXPOSED=8080
JWT_SECRET=troque-por-uma-chave-bem-longa-e-aleatoria-em-producao
JWT_ACCESS_EXP_MIN=15
JWT_REFRESH_EXP_DIAS=7
# Lista de origens permitidas no CORS, separadas por virgula (sem espaco depois da virgula).
# http://localhost e a origem do frontend servido pelo Nginx no docker-compose (porta 80).
# http://localhost:5173 e a origem do Vite quando voce roda o frontend fora do Docker (npm run dev).
FRONTEND_URL=http://localhost,http://localhost:5173
LOG_LEVEL=INFO

# Email (verificacao de conta e recuperacao de senha)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Adminer (UI pra inspecionar o banco em dev)
ADMINER_PORT_EXPOSED=8081

# Frontend
# Atencao: VITE_API_URL e "assado" dentro do bundle estatico no build,
# entao pra mudar em producao precisa rebuildar a imagem do frontend.
VITE_API_URL=http://localhost:8080
FRONTEND_PORT_EXPOSED=80
